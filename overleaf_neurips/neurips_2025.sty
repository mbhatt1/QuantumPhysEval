\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2025}[2026/04/04 Local NeurIPS-style template]

\newif\if@neuripsfinal
\@neuripsfinalfalse
\newif\if@natbibloaded
\@natbibloadedtrue

\DeclareOption{final}{\@neuripsfinaltrue}
\DeclareOption{preprint}{\@neuripsfinalfalse}
\DeclareOption{nonatbib}{\@natbibloadedfalse}
\ProcessOptions\relax

\RequirePackage[letterpaper]{geometry}
\geometry{
  textheight=9.0in,
  textwidth=6.25in,
  top=0.95in,
  headheight=14pt,
  headsep=18pt,
  footskip=24pt
}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}
\RequirePackage{xcolor}

\if@natbibloaded
  \RequirePackage[numbers,compress]{natbib}
\fi

\definecolor{neuripsblue}{HTML}{1F4E79}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.35em}
\pagestyle{fancy}
\fancyhf{}
\cfoot{\thepage}
\renewcommand{\headrulewidth}{0pt}

\titleformat{\section}{\large\bfseries}{\thesection}{0.5em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{0.5em}{}
\titleformat{\subsubsection}{\normalsize\bfseries}{\thesubsubsection}{0.5em}{}
\titlespacing*{\section}{0pt}{1.4ex plus .3ex minus .2ex}{0.6ex}
\titlespacing*{\subsection}{0pt}{1.1ex plus .2ex minus .2ex}{0.45ex}
\titlespacing*{\subsubsection}{0pt}{0.9ex plus .2ex minus .2ex}{0.35ex}

\renewenvironment{abstract}
  {\centerline{\bfseries Abstract}\vspace{0.5ex}\quotation\noindent}
  {\endquotation\vspace{1.0ex}}

\def\@maketitle{%
  \newpage
  \null
  \vskip 0.10in%
  \begin{center}%
    {\LARGE \bfseries \@title \par}%
    \vskip 0.12in%
    {\large
      \lineskip .5em%
      \begin{tabular}[t]{c}%
        \@author
      \end{tabular}\par}%
    \vskip 0.08in%
  \end{center}%
}

\renewcommand{\maketitle}{%
  \@maketitle
  \thispagestyle{fancy}
}

\AtBeginDocument{%
  \if@neuripsfinal
    \fancyhead[C]{}
  \else
    \fancyhead[C]{Preprint. Under review.}
  \fi
}
